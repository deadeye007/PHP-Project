# Database Configuration
DB_HOST=db
DB_NAME=learning_platform
DB_USER=root
DB_PASS=password

# MySQL Configuration for Docker
MYSQL_ROOT_PASSWORD=password
MYSQL_DATABASE=learning_platform

# Port Configuration
WEB_PORT=8080
DB_PORT=3306

# Application Environment
APP_ENV=development

# TinyMCE
# Create a TinyMCE implementation key and place it in your local .env file.
TINYMCE_API_KEY=your_tinymce_implementation_key_here

# HTTPS Configuration (important for secure cookies)
# Set to true if using HTTPS in production
# HTTPS_ENABLED=true
# Enable enforcement of HTTPS with a redirect if your hosting supports it
# HTTPS_REDIRECT=false
# Enable HTTP Strict Transport Security when HTTPS is active
# HTTPS_HSTS=false

# Other environment variables can be added here
